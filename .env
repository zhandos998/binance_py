# Безопасный режим по умолчанию: бот только симулирует сделки локально.
# Для demo futures исполнения поставь LIVE_TRADING=true.
LIVE_TRADING=true
USE_TEST_ORDER=false

# Binance Demo Trading USDT-M Futures.
FUTURES_DEMO=true
FUTURES_BASE_URL=https://demo-fapi.binance.com/fapi
ENSURE_ONE_WAY_MODE=true

# Настройки фьючерсов.
LEVERAGE=3
MARGIN_TYPE=ISOLATED

# Настройки сканирования рынка.
SCAN_INTERVAL_MINUTES=3
KLINE_INTERVAL=1m
KLINE_LIMIT=90
MAX_SYMBOLS=20
SYMBOL_SELECTION=volume
LOG_SCANNED_SYMBOLS=true
LOG_SCAN_SUMMARY=true
SCAN_SUMMARY_TOP_N=8
LOG_SYMBOL_DECISIONS=false
REQUEST_SLEEP_SECONDS=0.08
DRY_RUN_USDT_BALANCE=1000

# Настройки стратегии.
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
VOLUME_AVG_PERIOD=20
MOVEMENT_LOOKBACK_CANDLES=5
MOVEMENT_THRESHOLD_PCT=0.8
MIN_VOLUME_RATIO=1.5
BUY_RSI_MIN=50
BUY_RSI_MAX=72
SELL_RSI_MAX=45

# Риск-менеджмент.
# TRADE_RISK_PCT - максимум риска от депозита при срабатывании stop-loss.
TRADE_RISK_PCT=1.0
MAX_OPEN_POSITIONS=5
MAX_TRADES_PER_CYCLE=3
MIN_MARGIN_USDT=2
MAX_MARGIN_USDT=20
MIN_NOTIONAL_USDT=5
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=3.0

# Логи и состояние.
TRADE_LOG_FILE=futures_trades.csv
APP_LOG_FILE=bot.log
POSITIONS_FILE=futures_positions.json
