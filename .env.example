BINANCE_API_KEY=your_demo_futures_api_key
BINANCE_API_SECRET=your_demo_futures_api_secret

# Optional: load strategy overrides from .env.work, .env.test or .env.risky.
# Usually set this from PowerShell instead of hardcoding here.
# BOT_PROFILE_FILE=.env.test

# Безопасный режим по умолчанию: бот только симулирует сделки локально.
# Для demo futures исполнения поставь LIVE_TRADING=true.
LIVE_TRADING=false
USE_TEST_ORDER=false

# Binance Demo Trading USDT-M Futures.
FUTURES_DEMO=true
FUTURES_BASE_URL=https://demo-fapi.binance.com/fapi
FUTURES_QUOTE_ASSET=USDT
ENSURE_ONE_WAY_MODE=true

# Настройки фьючерсов.
LEVERAGE=3
MARGIN_TYPE=ISOLATED

# Настройки сканирования рынка.
SCAN_INTERVAL_MINUTES=3
KLINE_INTERVAL=1m
KLINE_LIMIT=90
MAX_SYMBOLS=0
SYMBOL_SELECTION=volume
SYMBOL_WHITELIST=
LOG_SCANNED_SYMBOLS=true
LOG_SCAN_SUMMARY=true
SCAN_SUMMARY_TOP_N=8
LOG_SYMBOL_DECISIONS=false
REQUEST_SLEEP_SECONDS=0.08
DRY_RUN_USDT_BALANCE=1000

# Настройки стратегии.
STRATEGY_MODE=momentum
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
VOLUME_AVG_PERIOD=20
MOVEMENT_LOOKBACK_CANDLES=5
MOVEMENT_THRESHOLD_PCT=0.8
MIN_VOLUME_RATIO=1.5
REQUIRE_EMA_TREND=true
BUY_RSI_MIN=50
BUY_RSI_MAX=72
SELL_RSI_MAX=45
HIGHER_TIMEFRAME_ENABLED=false
HIGHER_TIMEFRAME_INTERVAL=1h
HIGHER_TIMEFRAME_EMA_FAST=9
HIGHER_TIMEFRAME_EMA_SLOW=21
FUNDING_FILTER_ENABLED=false
MAX_LONG_FUNDING_RATE_PCT=0.03
MIN_SHORT_FUNDING_RATE_PCT=-0.03
MAX_ENTRY_SPREAD_PCT=0

# Риск-менеджмент.
# TRADE_RISK_PCT - максимум риска от депозита при срабатывании stop-loss.
TRADE_RISK_PCT=1.0
MAX_OPEN_POSITIONS=5
MAX_TRADES_PER_CYCLE=3
MIN_MARGIN_USDT=2
MAX_MARGIN_USDT=20
MIN_NOTIONAL_USDT=5
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=3.0
MAX_DAILY_LOSS_USDT=0
MAX_CONSECUTIVE_LOSSES=0
SYMBOL_COOLDOWN_MINUTES_AFTER_STOP=0
SYMBOL_COOLDOWN_MINUTES_AFTER_CLOSE=0
PLACE_PROTECTION_ORDERS=true
PROTECTION_WORKING_TYPE=MARK_PRICE
PROTECTION_PRICE_PROTECT=false
PROTECTION_TRIGGER_BUFFER_PCT=0.10
CANCEL_PROTECTION_ON_CLOSE=true

# Логи и состояние. SQLite используется как основное хранилище.
# CSV/JSON-файлы ниже нужны для lazy-миграции старых данных и fallback-режима статистики.
DATABASE_FILE=bot.sqlite3
TRADE_LOG_FILE=futures_trades.csv
APP_LOG_FILE=bot.log
POSITIONS_FILE=futures_positions.json
RISK_STATE_FILE=risk_state.json
